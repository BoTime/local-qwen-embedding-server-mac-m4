# Required: API key for clients. Generate with `openssl rand -hex 32`.
QWEN_API_KEY=change-me-to-a-secret-key

# Optional: multiple labeled keys (overrides QWEN_API_KEY when set).
# Each request's matched label is recorded in access logs and used as the
# rate-limit bucket. Format: comma-separated `label=key` pairs.
# QWEN_API_KEYS=alice=key-one,bob=key-two

# Optional: override the upstream Ollama URL (default: host.docker.internal).
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional: embedding model tag pulled in Ollama (default: qwen3-embedding:0.6b).
# EMBEDDING_MODEL=qwen3-embedding:0.6b

# Optional: per-key (or per-IP for unauthenticated requests) rate limit.
# Uses slowapi syntax; see https://limits.readthedocs.io/en/stable/quickstart.html#examples
# RATE_LIMIT=100/minute

# Required for the named Cloudflare Tunnel. Path to the credentials JSON written
# by `cloudflared tunnel create <name>`. Mounted into the cloudflared container.
CLOUDFLARE_CREDS_FILE=/Users/your-username/.cloudflared/<TUNNEL_UUID>.json
